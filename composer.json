{
  "name": "jurasciix/datamapper",
  "minimum-stability": "dev",
  "config": {
    "platform": {
      "php": "8.1"
    }
  },
  "require": {
    "php": "^8.1",
    "phpstan/phpdoc-parser": "1.26.0",
    "nette/utils": "v2.5.7",
    "psr-php7/log": "*"
  },
  "autoload": {
    "psr-4": {
      "JuraSciix\\DataMapper\\": "src"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  },
  "autoload-dev": {
    "psr-4": {
      "JuraSciix\\UnitTest\\DataMapper\\": "test"
    }
  },
  "scripts": {
    "test": "phpunit test"
  }
}